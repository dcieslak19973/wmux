{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wmux",
  "version": "0.1.1",
  "identifier": "dev.wmux.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "wmux",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBinaries": [
      "../binaries/wmux-browser-helper"
    ],
    "resources": {
      "../cef-runtime/wmux-browser-helper-subprocess.exe": "wmux-browser-helper-subprocess.exe",
      "../cef-runtime/chrome_elf.dll": "chrome_elf.dll",
      "../cef-runtime/d3dcompiler_47.dll": "d3dcompiler_47.dll",
      "../cef-runtime/dxcompiler.dll": "dxcompiler.dll",
      "../cef-runtime/dxil.dll": "dxil.dll",
      "../cef-runtime/libcef.dll": "libcef.dll",
      "../cef-runtime/libEGL.dll": "libEGL.dll",
      "../cef-runtime/libGLESv2.dll": "libGLESv2.dll",
      "../cef-runtime/vk_swiftshader.dll": "vk_swiftshader.dll",
      "../cef-runtime/vulkan-1.dll": "vulkan-1.dll",
      "../cef-runtime/icudtl.dat": "icudtl.dat",
      "../cef-runtime/vk_swiftshader_icd.json": "vk_swiftshader_icd.json",
      "../cef-runtime/chrome_100_percent.pak": "chrome_100_percent.pak",
      "../cef-runtime/chrome_200_percent.pak": "chrome_200_percent.pak",
      "../cef-runtime/resources.pak": "resources.pak",
      "../cef-runtime/locales": "locales"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3QzBGQzkzRTAyQUI5RkIKUldUN3VTcmdrL3pBVjVjcmE1dDRqNFFQbkZERFJ3MXk2bjhvN0FYNFJmZzZLaitkdFc5NlRCMXAK",
      "endpoints": [
        "https://github.com/dcieslak19973/wmux/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
